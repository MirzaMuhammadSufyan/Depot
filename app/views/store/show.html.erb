<div class="w-full max-w-4xl">
  <%= render "notice" %>

  <div class="flex flex-col md:flex-row gap-6">
    <div class="md:w-1/2">
      <%= image_tag @product.image,
        class: "object-contain w-full max-h-[28rem] bg-white rounded shadow p-3" %>
    </div>

    <div class="md:w-1/2">
      <h1 class="font-bold text-3xl mb-3"><%= @product.title %></h1>

      <div class="prose max-w-none mb-4">
        <%= sanitize(@product.description) %>
      </div>

      <div class="flex items-center gap-3">
        <div class="text-xl font-bold"><%= number_to_currency(@product.price) %></div>

        <%= button_to t("store.product.add_html"),
          line_items_path(product_id: @product),
          form_class: "inline",
          class: "rounded-lg py-2 px-3 text-white bg-green-600" %>
      </div>

      <div class="mt-6">
        <%= link_to t(".back"),
          store_index_path(locale: I18n.locale),
          class: "inline-block rounded-lg py-2 px-3 text-white bg-green-600" %>
      </div>
    </div>
  </div>
</div>
