<fieldset data-payment-target="additionalFields" data-type="Credit card">
  <div class="my-5">
    <%= form.label :credit_card_number, "CC #" %>
    <%= form.password_field :credit_card_number, class: "input-field" %>
  </div>
  <div class="my-5">
    <%= form.label :expiration_date, "Expiry" %>
    <%= form.text_field :expiration_date, placeholder: "e.g. 03/26", class: "input-field" %>
  </div>
</fieldset>
